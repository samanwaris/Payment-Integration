    "/api/payment/settlement-snap": {
      "post": {
        "tags": [
          "Payment"
        ],
        "parameters": [
          {
            "name": "X-SIGNATURE",
            "in": "header",
            "description": "Signature for request validation",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-TIMESTAMP",
            "in": "header",
            "description": "ISO8601 timestamp (yyyy-MM-ddTHH:mm:sszzz)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "2026-04-17T10:00:00+07:00"
            }
          },
          {
            "name": "X-PARTNER-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-EXTERNAL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "CHANNEL-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SnapSettlement"
              }
            },
            "text/json": {
